import maya.cmds as cmds


# ------------------------------------------------------------
# CORE GLOBAL SCALE LOGIC
# ------------------------------------------------------------

def remove_global_scale(control_name, skeleton_group=None):
    """Removes all global scale connections created by this tool."""

    if not cmds.objExists(control_name):
        return

    # Remove scaleConstraint from skeleton group
    if skeleton_group and cmds.objExists(skeleton_group):
        constraints = cmds.listRelatives(
            skeleton_group, type="scaleConstraint", allDescendents=False
        ) or []
        if constraints:
            cmds.delete(constraints)

    # Disconnect globalScale from control scale + unlock
    if cmds.attributeQuery("globalScale", node=control_name, exists=True):
        for axis in ["X", "Y", "Z"]:
            scale_attr = f"{control_name}.scale{axis}"
            incoming = cmds.listConnections(scale_attr, source=True, plugs=True) or []
            for src in incoming:
                if "globalScale" in src:
                    try:
                        cmds.disconnectAttr(src, scale_attr)
                    except Exception:
                        pass

            if cmds.getAttr(scale_attr, lock=True):
                cmds.setAttr(scale_attr, lock=False, keyable=True, channelBox=True)

    # Delete multiplyDivide nodes created by this tool
    md_nodes = cmds.ls("*_globalScale_md", type="multiplyDivide") or []
    if md_nodes:
        cmds.delete(md_nodes)


def create_global_scale_attr(control_name):
    """Creates and connects globalScale on the control."""

    if not cmds.attributeQuery("globalScale", node=control_name, exists=True):
        cmds.addAttr(
            control_name,
            ln="globalScale",
            at="double",
            dv=1.0,
            min=0.001,
            keyable=True
        )

    for axis in ["X", "Y", "Z"]:
        cmds.connectAttr(
            f"{control_name}.globalScale",
            f"{control_name}.scale{axis}",
            force=True
        )
        cmds.setAttr(
            f"{control_name}.scale{axis}",
            lock=True,
            keyable=False,
            channelBox=False
        )


def apply_global_scale(control_name, skeleton_group):
    """Full rebuild-safe global scale setup."""

    if not cmds.objExists(control_name) or not cmds.objExists(skeleton_group):
        cmds.warning("Invalid control or skeleton group.")
        return

    # Always clean first
    remove_global_scale(control_name, skeleton_group)

    # Create control attr
    create_global_scale_attr(control_name)

    # Scale constraint drives skeleton
    cmds.scaleConstraint(control_name, skeleton_group, maintainOffset=True)

    # Disable segment scale compensate on all joints
    for joint in cmds.ls(type="joint"):
        if cmds.objExists(f"{joint}.segmentScaleCompensate"):
            cmds.setAttr(f"{joint}.segmentScaleCompensate", 0)

    cmds.confirmDialog(
        title="Global Scale Applied",
        message="Global scale rebuilt successfully.\nNew joints are now included.",
        button=["OK"]
    )


# CLEAN UI

def open_global_scale_ui():

    if cmds.window("globalScaleUI", exists=True):
        cmds.deleteUI("globalScaleUI")

    window = cmds.window(
        "globalScaleUI",
        title="Global Scale",
        widthHeight=(300, 120),
        sizeable=False
    )

    cmds.columnLayout(adjustableColumn=True, rowSpacing=8)

    cmds.text(label="Global Scale Setup", align="center", font="boldLabelFont")

    control_field = cmds.textFieldButtonGrp(
        "gs_controlField",
        label="Control",
        buttonLabel="Pick",
        columnWidth=[(1, 60), (2, 170), (3, 50)],
        bc=lambda: cmds.textFieldButtonGrp(
            "gs_controlField",
            edit=True,
            text=cmds.ls(sl=True)[0] if cmds.ls(sl=True) else ""
        )
    )

    skeleton_field = cmds.textFieldButtonGrp(
        "gs_skeletonField",
        label="Skeleton",
        buttonLabel="Pick",
        columnWidth=[(1, 60), (2, 170), (3, 50)],
        bc=lambda: cmds.textFieldButtonGrp(
            "gs_skeletonField",
            edit=True,
            text=cmds.ls(sl=True)[0] if cmds.ls(sl=True) else ""
        )
    )

    cmds.separator(height=10, style="in")

    cmds.button(
        label="Apply / Rebuild Global Scale",
        height=30,
        command=lambda _: apply_global_scale(
            cmds.textFieldButtonGrp("gs_controlField", q=True, text=True),
            cmds.textFieldButtonGrp("gs_skeletonField", q=True, text=True)
        )
    )

    cmds.showWindow(window)


open_global_scale_ui()
